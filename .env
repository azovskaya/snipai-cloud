# === LLM (OpenRouter & Qwen) ===
# Замени 'sk-or-v1-...' на твой реальный ключ от OpenRouter
OPENROUTER_API_KEY=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
# Рекомендую эту модель: она бесплатная, мощная и отлично понимает русский
LLM_MODEL=qwen/qwen-2.5-72b-instruct

# === Parsing (LlamaParse) ===
LLAMA_CLOUD_API_KEY=

# === Vector Database (Qdrant) ===
# Внутри Docker-сети используем имя сервиса 'qdrant'
QDRANT_HOST=qdrant
QDRANT_PORT=6333
COLLECTION_NAME=snips_rk_test

# === Embedding Model (Local) ===
# Эта модель будет скачана в Docker-volume и работать локально
EMBED_MODEL=intfloat/multilingual-e5-small

# === Настройки Docker / Python ===
PYTHONUNBUFFERED=1